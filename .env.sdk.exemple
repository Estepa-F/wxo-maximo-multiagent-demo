# watsonx Orchestrate configuration
WO_DEVELOPER_EDITION_SOURCE="orchestrate"
WO_INSTANCE_ALIAS=wxo-saas
WO_INSTANCE=https://your-watsonx-orchestrate-instance
WO_API_KEY=your-api-key

# ServiceNow OAuth 2.0 configuration
SN_INSTANCE_URL=https://dev123456.service-now.com
SN_USERNAME=your-service-account-username
SN_PASSWORD=your-service-account-password
SN_CLIENT_ID=your-oauth-client-id
SN_CLIENT_SECRET=your-oauth-client-secret

# Maximo API Key configuration
MAXIMO_URL=https://your-maximo-instance/maximo
MAXIMO_API_KEY=your-maximo-api-key-here

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# Slack Webhook configuration
SLACK_WEBHOOK_URL=your-url-webhook